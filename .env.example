# ─── Supabase ────────────────────────────────────────────────────────────────
# Project URL and anon key — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key — server-only, never in client code
# Used ONLY in: migrations, webhook handlers, account deletion
SUPABASE_SERVICE_ROLE_KEY=

# ─── Database (Prisma) ───────────────────────────────────────────────────────
# Use Supabase's connection pooler URL for DATABASE_URL (port 6543, ?pgbouncer=true)
# Use the direct connection URL for DIRECT_URL (port 5432, for migrations)
# Both are found in: Supabase Dashboard → Settings → Database → Connection string
DATABASE_URL=
DIRECT_URL=

# ─── App ─────────────────────────────────────────────────────────────────────
# Your production URL (no trailing slash). Used in auth callbacks and email links.
NEXT_PUBLIC_APP_URL=

# ─── Inngest (background jobs) ───────────────────────────────────────────────
# Found in the Inngest dashboard → your app → Event Key / Signing Key
# Leave blank in local dev if not using Inngest locally
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ─── AI (Anthropic) ──────────────────────────────────────────────────────────
# Required for Phase 2+ AI features. Leave blank for Phase 1 (deterministic only).
ANTHROPIC_API_KEY=

# ─── Email (Resend) ──────────────────────────────────────────────────────────
# Required for digest emails. Leave blank until email is wired up.
RESEND_API_KEY=

# ─── Billing (Stripe) ────────────────────────────────────────────────────────
# Required for Phase 3 subscription features. Leave blank for Phase 1.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
